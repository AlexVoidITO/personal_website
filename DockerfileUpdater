FROM alpine:latest

RUN apk add --no-cache git bash curl


COPY update.sh /usr/local/bin/update.sh
RUN chmod +x /usr/local/bin/update.sh


RUN apk add --no-cache dcron


RUN echo "*/5 * * * * /usr/local/bin/update.sh >> /var/log/cron.log 2>&1" > /etc/crontab


COPY entrypoint-updater.sh /usr/local/bin/entrypoint-updater.sh
RUN chmod +x /usr/local/bin/entrypoint-updater.sh

ENTRYPOINT ["/usr/local/bin/entrypoint-updater.sh"]